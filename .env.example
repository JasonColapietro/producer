# ─────────────────────────────────────────────────────────────────────────────
# TubeForge env. Copy to .env and fill in. In production these are set in the
# Vercel (web) and Render (worker) dashboards.
#
# Multi-tenant note: per-channel keys live in the DB (channels.secrets). These
# env vars are the SINGLE-TENANT defaults / fallback used in v1 and local dev.
# ─────────────────────────────────────────────────────────────────────────────

# Shared brain — Neon Postgres.
# DATABASE_URL = POOLED (has "-pooler" in host) — used at runtime by Vercel + Render.
# DATABASE_URL_UNPOOLED = DIRECT (no "-pooler") — used only by `pnpm db:push` (DDL needs a direct conn).
DATABASE_URL="postgresql://user:pass@ep-xxx-pooler.region.aws.neon.tech/tubeforge?sslmode=require"
DATABASE_URL_UNPOOLED="postgresql://user:pass@ep-xxx.region.aws.neon.tech/tubeforge?sslmode=require"

# Asset storage — Vercel Blob (Project Settings → Storage → Blob → read/write token)
BLOB_READ_WRITE_TOKEN="vercel_blob_rw_xxx"

# Script brain — Anthropic
ANTHROPIC_API_KEY="sk-ant-xxx"
ANTHROPIC_MODEL="claude-fable-5"

# Owner (single-tenant v1 bootstrap) + default faceless voice reference clip.
# voiceRefUrl on a channel overrides this; it's the fallback narrator voice.
OWNER_EMAIL="you@example.com"
STOCK_VOICE_REF_URL="https://your-blob-host/neutral-voice-sample.wav"

# GPU, by the second — Replicate (voice clone, avatar, Flux images, Whisper)
REPLICATE_API_TOKEN="r8_xxx"

# Free B-roll
PEXELS_API_KEY="xxx"
PIXABAY_API_KEY="xxx"

# YouTube OAuth (one app; each channel authorizes once and we store a refresh token)
GOOGLE_CLIENT_ID="xxx.apps.googleusercontent.com"
GOOGLE_CLIENT_SECRET="xxx"
GOOGLE_OAUTH_REDIRECT="http://localhost:3000/api/youtube/callback"

# Cron / internal auth — protect the Vercel cron + worker-trigger endpoints
CRON_SECRET="generate-a-long-random-string"

# Worker
WORKER_POLL_MS="5000"
