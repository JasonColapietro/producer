{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "rootDirectory": "apps/web",
  "installCommand": "pnpm install",
  "buildCommand": "pnpm --filter @tubeforge/web build",
  "ignoreCommand": "[ \"$VERCEL_ENV\" != \"production\" ] && exit 0 || exit 1",
  "crons": [
    {
      "path": "/api/cron/tick",
      "schedule": "0 9 * * *"
    }
  ]
}
