{
  "name": "tubeforge",
  "private": true,
  "version": "0.1.0",
  "description": "Faceless + avatar YouTube automation. BYO-keys, tenant-ready. Vercel dashboard + cron, Render worker, Replicate GPU.",
  "packageManager": "pnpm@11.1.3",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "build": "pnpm -r build",
    "typecheck": "pnpm -r typecheck",
    "db:push": "pnpm --filter @tubeforge/core db:push",
    "db:studio": "pnpm --filter @tubeforge/core db:studio",
    "worker": "pnpm --filter @tubeforge/worker start",
    "worker:dev": "pnpm --filter @tubeforge/worker dev",
    "web:dev": "pnpm --filter @tubeforge/web dev"
  },
  "devDependencies": {
    "tsx": "^4.19.2",
    "typescript": "^5.7.3"
  }
}
