{
  "name": "@producer/worker",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "esbuild src/index.ts --bundle --platform=node --target=node22 --outfile=dist/worker.cjs --external:sharp --external:ffmpeg-static",
    "start": "node dist/worker.cjs",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@producer/core": "workspace:*",
    "tsx": "^4.19.2"
  },
  "devDependencies": {
    "@types/node": "^22.10.5",
    "esbuild": "^0.24.0",
    "typescript": "^5.7.3"
  }
}
